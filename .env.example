NODE_ENV=development
DATABASE_URL=postgresql://autopilotops:autopilotops@localhost:5432/autopilotops?schema=public
REDIS_URL=redis://localhost:6379
JWT_SECRET=replace-me-with-at-least-32-characters-dev
JWT_PREVIOUS_SECRETS=
JWT_ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_SECRET=replace-me-with-at-least-32-characters-cookie
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:3000
API_PORT=4040
AUTH_RATE_LIMIT_MAX=10
SENSITIVE_RATE_LIMIT_MAX=60
SIGNAL_RATE_LIMIT_MAX=120
APPROVAL_RATE_LIMIT_MAX=60
ADMIN_RATE_LIMIT_MAX=60
RULE_RATE_LIMIT_MAX=60
LOG_LEVEL=info
WORKER_CONCURRENCY=5
ACTION_WORKER_CONCURRENCY=5
ACTION_MAX_ATTEMPTS=3
ACTION_LOCK_TTL_SECONDS=120
OUTBOX_DISPATCH_INTERVAL_MS=1000
OUTBOX_DISPATCH_BATCH_SIZE=25
